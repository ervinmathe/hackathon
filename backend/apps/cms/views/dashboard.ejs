<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hackathon Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.min.css">
    <style>
        .section { margin-bottom: 4rem; border-bottom: 2px solid #eee; padding-bottom: 3rem; }
        /* Improved Grid: force single column on smaller screens, ensure enough space */
        .grid { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
        @media (min-width: 1200px) {
            .grid { grid-template-columns: 3fr 2fr; }
        }
        .badge { font-size: 0.8rem; padding: 0.2rem 0.5rem; border-radius: 5px; background: #eee; }
        /* Table protection */
        .table-container { overflow-x: auto; width: 100%; margin-bottom: 1rem; border: 1px solid #eee; border-radius: 8px; }
        table { font-size: 0.85rem; width: 100%; margin-bottom: 0; }
        th, td { padding: 0.5rem 0.75rem !important; }
        button.outline { padding: 0.2rem 0.5rem; font-size: 0.75rem; width: auto; min-width: 70px; margin-bottom: 0; }
        
        /* Form styling */
        form { background: #fdfdfd; padding: 1.5rem; border: 1px solid #e0e0e0; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        form h3 { margin-top: 0; font-size: 1.2rem; }
        input, select, textarea { margin-bottom: 0.75rem !important; font-size: 0.9rem; }
        
        /* Search styling */
        .search-container { margin-bottom: 1rem; }
        .search-input { border-radius: 20px !important; padding-left: 1rem !important; }
    </style>
</head>
<body>
    <nav class="container-fluid">
        <ul>
            <li><strong>Hackathon CMS Admin</strong> <span class="badge"><%= userRole %></span></li>
        </ul>
        <ul>
            <li><a href="/logout" class="secondary">Kijelentkezés</a></li>
        </ul>
    </nav>
    <main class="container">

        <!-- EGYETEMEK (Csak ADMIN) -->
        <% if (userRole === 'ADMIN') { %>
        <section class="section">
            <div class="grid">
                <div>
                    <h3>Egyetemek</h3>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Név</th>
                                    <th>Művelet</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% universities.forEach(u => { %>
                                    <tr>
                                        <td><%= u.name %></td>
                                        <td><button class="outline contrast" onclick="deleteItem('universities', '<%= u.id %>')">Törlés</button></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div>
                    <form onsubmit="handleCreate(event, 'universities')">
                        <h3>Új egyetem</h3>
                        <input type="text" name="name" placeholder="Egyetem neve" required>
                        <textarea name="description" placeholder="Leírás"></textarea>
                        <button type="submit">Hozzáadás</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- SZAKOK (Csak ADMIN) -->
        <section class="section">
            <div class="grid">
                <div>
                    <h3>Szakok</h3>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Név</th>
                                    <th>Egyetem</th>
                                    <th>Művelet</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% enrollments.forEach(e => { %>
                                    <tr>
                                        <td><%= e.name %></td>
                                        <td><%= e.university_name %></td>
                                        <td><button class="outline contrast" onclick="deleteItem('enrollments', '<%= e.id %>')">Törlés</button></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div>
                    <form onsubmit="handleCreate(event, 'enrollments')">
                        <h3>Új szak</h3>
                        <input type="text" name="name" placeholder="Szak neve" required>
                        <select name="university_id" required>
                            <option value="" disabled selected>Válassz egyetemet...</option>
                            <% universities.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.name %></option>
                            <% }) %>
                        </select>
                        <textarea name="description" placeholder="Leírás"></textarea>
                        <button type="submit">Hozzáadás</button>
                    </form>
                </div>
            </div>
        </section>
        <% } %>

        <!-- TANTÁRGYAK (ADMIN és LESSADMIN is) -->
        <section class="section">
            <div class="grid">
                <div>
                    <h3>Tantárgyak / Fórumok</h3>
                    <div class="search-container">
                        <input type="text" class="search-input" placeholder="Keresés tantárgyak között..." onkeyup="filterTable(this, 'forums-table')">
                    </div>
                    <div class="table-container">
                        <table id="forums-table">
                            <thead>
                                <tr>
                                    <th>Név</th>
                                    <th>Egyetem</th>
                                    <th>Szak</th>
                                    <th>Művelet</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% forums.forEach(f => { %>
                                    <tr>
                                        <td><%= f.name %></td>
                                        <td><%= f.university_name %></td>
                                        <td><%= f.enrollment_name ? f.enrollment_name : 'Minden szak' %></td>
                                        <td><button class="outline contrast" onclick="deleteItem('forums', '<%= f.id %>')">Törlés</button></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div>
                    <form onsubmit="handleCreate(event, 'forums')">
                        <h3>Új tantárgy</h3>
                        <input type="text" name="name" placeholder="Tantárgy neve" required>
                        <select name="university_id" required>
                            <option value="" disabled selected>Válassz egyetemet...</option>
                            <% universities.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.name %></option>
                            <% }) %>
                        </select>
                        <select name="enrollment_id" required>
                            <option value="" disabled selected>Válassz szakot...</option>
                            <% enrollments.forEach(e => { %>
                                <option value="<%= e.id %>"><%= e.name %></option>
                            <% }) %>
                        </select>
                        <textarea name="description" placeholder="Leírás"></textarea>
                        <button type="submit">Hozzáadás</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- FELHASZNÁLÓK (Csak ADMIN) -->
        <% if (userRole === 'ADMIN') { %>
        <section class="section">
            <div class="grid">
                <div>
                    <h3>Felhasználók</h3>
                    <div class="search-container">
                        <input type="text" class="search-input" placeholder="Keresés felhasználók között (név/email)..." onkeyup="filterTable(this, 'users-table')">
                    </div>
                    <div class="table-container">
                        <table id="users-table">
                            <thead>
                                <tr>
                                    <th>Név (Email)</th>
                                    <th>Szerepkör</th>
                                    <th>Egyetem / Szak</th>
                                    <th>Művelet</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                    <tr>
                                        <td><%= u.username %> (<%= u.email %>)</td>
                                        <td><span class="badge"><%= u.role %></span></td>
                                        <td><%= u.university_name %> / <%= u.enrollment_name || '-' %></td>
                                        <td><button class="outline contrast" onclick="deleteItem('users', '<%= u.id %>')">Törlés</button></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div>
                    <form onsubmit="handleCreate(event, 'users')">
                        <h3>Új Admin/LessAdmin</h3>
                        <input type="text" name="username" placeholder="Felhasználónév" required>
                        <input type="email" name="email" placeholder="Email" required>
                        <input type="password" name="password" placeholder="Jelszó" required>
                        <select name="role" required>
                            <option value="LESSADMIN">LESSADMIN (Fórum kezelő)</option>
                            <option value="ADMIN">ADMIN (Teljes jogú)</option>
                            <option value="USER">USER (Hallgató)</option>
                        </select>
                        <select name="university_id" required>
                            <option value="" disabled selected>Válassz egyetemet...</option>
                            <% universities.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.name %></option>
                            <% }) %>
                        </select>
                        <button type="submit">Létrehozás</button>
                    </form>
                </div>
            </div>
        </section>
        <% } %>

        <!-- POSZTOK (Moderáció - ADMIN és LESSADMIN is) -->
        <section class="section">
            <h3>Posztok / Jegyzetek (Moderáció)</h3>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Állapot</th>
                            <th>Cím</th>
                            <th>Tantárgy</th>
                            <th>Szerző</th>
                            <th>Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% posts.forEach(p => { %>
                            <tr style="<%= p.is_pinned ? 'background-color: #fff8e1;' : '' %>">
                                <td>
                                    <% if (p.is_pinned) { %>
                                        <span class="badge" style="background: #ffd54f;">PINNED</span>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td><%= p.title %></td>
                                <td><%= p.forum_name %></td>
                                <td><%= p.author_name %></td>
                                <td>
                                    <button class="outline" onclick="togglePin('<%= p.id %>')">
                                        <%= p.is_pinned ? 'Unpin' : 'Pin' %>
                                    </button>
                                    <button class="outline contrast" onclick="deleteItem('posts', '<%= p.id %>')">Törlés</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- HOZZÁSZÓLÁSOK (Moderáció - ADMIN és LESSADMIN is) -->
        <section class="section">
            <h3>Hozzászólások (Moderáció)</h3>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Tartalom</th>
                            <th>Poszt</th>
                            <th>Szerző</th>
                            <th>Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (typeof comments !== 'undefined' ? comments : []).forEach(c => { %>
                            <tr>
                                <td style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    <%= c.content %>
                                </td>
                                <td><%= c.post_title %></td>
                                <td><%= c.author_name %></td>
                                <td><button class="outline contrast" onclick="deleteItem('comments', '<%= c.id %>')">Törlés</button></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- NAPTÁR (Moderáció - ADMIN és LESSADMIN is) -->
        <section class="section">
            <h3>Naptár Események (Moderáció)</h3>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Státusz</th>
                            <th>Cím</th>
                            <th>Egyetem</th>
                            <th>Szerző</th>
                            <th>Időpont</th>
                            <th>Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (typeof events !== 'undefined' ? events : []).forEach(e => { %>
                            <tr style="<%= !e.is_approved ? 'background-color: #fff3e0;' : '' %>">
                                <td>
                                    <% if (e.is_approved) { %>
                                        <span class="badge" style="background: #c8e6c9;">Approved</span>
                                    <% } else { %>
                                        <span class="badge" style="background: #ffe0b2;">Pending</span>
                                    <% } %>
                                </td>
                                <td><%= e.title %></td>
                                <td><%= e.university_name %></td>
                                <td><%= e.author_name %></td>
                                <td><%= new Date(e.start_time).toLocaleString('hu-HU') %></td>
                                <td>
                                    <% if (!e.is_approved) { %>
                                        <button class="outline" onclick="approveEvent('<%= e.id %>')">Jóváhagyás</button>
                                    <% } %>
                                    <button class="outline contrast" onclick="deleteItem('calendar', '<%= e.id %>')">Törlés</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>

    </main>

    <script>
        function filterTable(input, tableId) {
            const filter = input.value.toLowerCase();
            const table = document.getElementById(tableId);
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                let found = false;
                const td = tr[i].getElementsByTagName("td");
                for (let j = 0; j < td.length - 1; j++) { // Exclude actions column
                    if (td[j] && td[j].innerText.toLowerCase().indexOf(filter) > -1) {
                        found = true;
                        break;
                    }
                }
                tr[i].style.display = found ? "" : "none";
            }
        }

        async function deleteItem(resource, id) {
            if (!confirm('Biztosan törölni szeretnéd?')) return;
            const res = await fetch(`/admin/${resource}/${id}`, { method: 'DELETE' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Hiba történt a törlés során.');
            }
        }

        async function togglePin(id) {
            const res = await fetch(`/posts/${id}/pin`, { method: 'PATCH' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Hiba történt a pinelés során.');
            }
        }

        async function approveEvent(id) {
            const res = await fetch(`/calendar/${id}/approve`, { method: 'PATCH' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Hiba történt a jóváhagyás során.');
            }
        }

        async function handleCreate(event, resource) {
            event.preventDefault();
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());

            const res = await fetch(`/admin/${resource}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                location.reload();
            } else {
                const err = await res.json();
                alert('Hiba: ' + (err.message || 'Ismeretlen hiba'));
            }
        }
    </script>
</body>
</html>
